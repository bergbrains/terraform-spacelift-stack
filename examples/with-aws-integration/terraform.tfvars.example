# Copy this file to terraform.tfvars and fill in your own values before running.

aws_region             = "us-east-1"
aws_account_id         = "123456789012"
name                   = "example-stack"
spacelift_account_name = "cloud-admin"
repository_name        = "my-github-repo"
repository_branch      = "main"
description            = "Example stack with AWS integration."
